# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Foundry AI Configuration (required at build time)
VITE_FOUNDRY_ENDPOINT=https://your-foundry-endpoint.com
VITE_FOUNDRY_API_KEY=your-foundry-api-key
VITE_FOUNDRY_API_VERSION=2025-01-01-preview

# App
VITE_APP_NAME=FoundryForge
VITE_APP_URL=http://localhost:5173

# ── Production-only (set in Vercel dashboard, NOT in .env) ──
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_CLIENT_ID=your-azure-client-id
# AZURE_CLIENT_SECRET=your-azure-client-secret
# FOUNDRY_ENDPOINT=https://your-foundry-endpoint.com
